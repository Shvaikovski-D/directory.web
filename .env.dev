# Конфигурация подключения к PostgreSQL для разработки
# Измените эти значения на параметры вашей локальной базы данных

POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=TestTaskDb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=111

# Окружение ASP.NET Core для разработки
ASPNETCORE_ENVIRONMENT=Development